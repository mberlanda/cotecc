{
  "name": "CoteccApp",
  "version": "1.2.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo run:android",
    "clean": "rm -rf .expo coverage node_modules",
    "embed:web": "node scripts/embed-web-bundle.js",
    "embed:verify": "node scripts/verify-embedded-bundle.js",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "cd .. && husky install CoteccApp/.husky",
    "start": "expo start",
    "test": "jest",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "^56.0.11",
    "expo-constants": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.10",
    "expo-splash-screen": "~56.0.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.0",
    "babel-jest": "^29.6.3",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~56.0.4",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.3",
    "jest": "^29.6.3",
    "jest-expo": "~56.0.5",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
